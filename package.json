{
  "name": "lab3-mongodb-codesandbox",
  "version": "1.0.0",
  "scripts": {
    "postinstall": "cd frontend && npm install && cd ../backend && npm install",
    "start": "concurrently \"npm run start:backend\" \"npm run start:frontend\"",
